{
  "name": "fileonchain",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "overrides": {
      "@polkadot/util": "13.5.9",
      "@polkadot/util-crypto": "13.5.9",
      "@polkadot/keyring": "13.5.9",
      "@polkadot/api": "15.10.2",
      "@polkadot/types": "15.10.2"
    },
    "onlyBuiltDependencies": [
      "bufferutil",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver",
      "utf-8-validate"
    ]
  },
  "scripts": {
    "dev": "pnpm --filter @fileonchain/web dev",
    "build": "pnpm -r build",
    "start": "pnpm --filter @fileonchain/web start",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "test": "pnpm -r test"
  }
}
