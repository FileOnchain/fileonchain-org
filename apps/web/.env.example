# Public origin used for canonical URLs, Open Graph, sitemap.xml, and robots.txt.
# Origin only, no trailing slash. Falls back to https://fileonchain.org when unset.
NEXT_PUBLIC_SITE_URL=https://fileonchain.org

# Google Analytics 4 measurement id (looks like G-XXXXXXXXXX). Leave empty to
# disable analytics — the <GoogleAnalytics> tag only mounts when this is set.
NEXT_PUBLIC_GA_ID=

# Google Search Console verification token (the `content` value from the
# "HTML tag" verification method). Server-only — no NEXT_PUBLIC_ prefix. When
# set, a <meta name="google-site-verification"> tag is emitted in <head>.
GOOGLE_SITE_VERIFICATION=

# Neon Postgres pooled connection string (postgres://…-pooler.…neon.tech/…).
# Required for auth, the dashboard, credits, API keys, and BYOK.
DATABASE_URL=

# Auth.js session encryption secret. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Canonical app URL for Auth.js callbacks. Optional — inferred in most
# environments; set explicitly for local dev if callbacks misbehave.
# AUTH_URL=http://localhost:3000

# OAuth sign-in providers. All optional — a provider's button is hidden on
# /login when its credentials are unset, so wallet sign-in works without them.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# 32-byte base64 key used to AES-256-GCM encrypt BYOK provider API keys at
# rest. Generate with: openssl rand -base64 32
BYOK_ENCRYPTION_KEY=

# Funded server signers for the credits/BYOK anchor worker. Both optional —
# when unset (or the chain has nothing deployed), the worker falls back to a
# deterministic mock anchor. Fund these accounts on every chain they serve.
# EVM: 0x-prefixed private key used for FileRegistry.anchorCID sends.
ANCHOR_EVM_PRIVATE_KEY=
# Substrate: secret URI (mnemonic or //derivation) for remark anchors.
ANCHOR_SUBSTRATE_SEED=
