# Deploy configuration for script/Deploy.s.sol — copy to .env (gitignored);
# forge loads it automatically from this directory. Full runbook:
# docs/deploy/evm.md.

# Deployer key. Required. Funded with native gas on the target chain. For
# mainnets prefer a Foundry keystore over a plaintext key: import once with
# `cast wallet import deployer --interactive`, leave PRIVATE_KEY unset, and
# run forge script with `--account deployer` instead.
PRIVATE_KEY=

# Treasury receiving CachePayments revenue and DonationEscrow funds. Required.
TREASURY_ADDRESS=

# FileOnChain platform-fee treasury (25% tip share). Defaults to
# TREASURY_ADDRESS when unset.
# PLATFORM_TREASURY_ADDRESS=

# FOCAT minted to the deployer. Default 1e27 (1B FOCAT). MUST be 0 on every
# chain except the home chain — remote supply arrives via bridges only.
# TOKEN_INITIAL_SUPPLY=0

# Governance parameters. Defaults: 2-day timelock, ~1-day voting delay
# (7200 blocks), ~1-week voting period (50400 blocks), 100k FOCAT threshold.
# TIMELOCK_MIN_DELAY=172800
# GOVERNOR_VOTING_DELAY=7200
# GOVERNOR_VOTING_PERIOD=50400
# GOVERNOR_PROPOSAL_THRESHOLD=100000000000000000000000

# The chain's canonical USDC for CachePayments. Leave unset on testnets and
# the script deploys a MockUSDC; ALWAYS set the real USDC on mainnets.
# USDC_ADDRESS=

# RPC endpoints referenced by [rpc_endpoints] in foundry.toml
# (forge script --rpc-url base, etc.). Canonical URLs live on the chain
# entries in packages/utils/src/chains.ts.
# MAINNET_RPC_URL=
# SEPOLIA_RPC_URL=
# AUTO_EVM_RPC_URL=https://auto-evm.mainnet.autonomys.xyz/ws
# CHRONOS_RPC_URL=https://auto-evm.chronos.autonomys.xyz/ws
# BASE_RPC_URL=
# OPTIMISM_RPC_URL=
# ARBITRUM_RPC_URL=
# POLYGON_RPC_URL=

# Explorer API keys for --verify (Etherscan-family), per [etherscan] in
# foundry.toml.
# ETHERSCAN_API_KEY=
# BASESCAN_API_KEY=
# OPTIMISTIC_ETHERSCAN_API_KEY=
# ARBISCAN_API_KEY=
# POLYGONSCAN_API_KEY=
