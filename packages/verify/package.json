{
  "name": "@fileonchain/verify",
  "version": "0.1.0",
  "description": "Deterministic local verifier for FileOnChain evidence packages — hashes, signatures, Merkle inclusion, and settlement receipts, with no FileOnChain service in the loop.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FileOnchain/fileonchain-org.git",
    "directory": "packages/verify"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "bin": {
    "fileonchain-verify": "./dist/cli.js"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fileonchain/utils": "workspace:^",
    "viem": "^2.53.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.5.0",
    "typescript": "^5"
  }
}
