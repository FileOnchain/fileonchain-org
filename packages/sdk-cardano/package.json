{
  "name": "@fileonchain/sdk-cardano",
  "version": "0.1.0",
  "description": "FileOnChain Cardano client — anchor CIDs via CIP-20 transaction metadata.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FileOnchain/fileonchain-org.git",
    "directory": "packages/sdk-cardano"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
