        "require": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fileonchain/utils": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.5.0",
    "typescript": "^5"
  }
}
