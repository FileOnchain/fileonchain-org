{
  "name": "@fileonchain/sdk",
  "version": "0.1.0",
  "description": "The FileOnChain reference SDK \u2014 evidence creation and agent-run sealing on the FileOnChain Evidence Protocol, plus the chain registry, anchor clients per family, and the hosted API client.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FileOnchain/fileonchain-org.git",
    "directory": "packages/sdk"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./evm": "./src/evm.ts",
    "./substrate": "./src/substrate.ts",
    "./solana": "./src/solana.ts",
    "./aptos": "./src/aptos.ts",
    "./cosmos": "./src/cosmos.ts",
    "./sui": "./src/sui.ts",
    "./starknet": "./src/starknet.ts",
    "./near": "./src/near.ts",
    "./tron": "./src/tron.ts",
    "./cardano": "./src/cardano.ts",
    "./ton": "./src/ton.ts",
    "./hedera": "./src/hedera.ts",
    "./api": "./src/api.ts",
    "./protocol": "./src/protocol.ts",
    "./agent-profile": "./src/agent-profile.ts",
    "./evidence": "./src/evidence.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./evm": {
        "types": "./dist/evm.d.ts",
        "import": "./dist/evm.js",
        "require": "./dist/evm.cjs"
      },
      "./substrate": {
        "types": "./dist/substrate.d.ts",
        "import": "./dist/substrate.js",
        "require": "./dist/substrate.cjs"
      },
      "./solana": {
        "types": "./dist/solana.d.ts",
        "import": "./dist/solana.js",
        "require": "./dist/solana.cjs"
      },
      "./aptos": {
        "types": "./dist/aptos.d.ts",
        "import": "./dist/aptos.js",
        "require": "./dist/aptos.cjs"
      },
      "./cosmos": {
        "types": "./dist/cosmos.d.ts",
        "import": "./dist/cosmos.js",
        "require": "./dist/cosmos.cjs"
      },
      "./sui": {
        "types": "./dist/sui.d.ts",
        "import": "./dist/sui.js",
        "require": "./dist/sui.cjs"
      },
      "./starknet": {
        "types": "./dist/starknet.d.ts",
        "import": "./dist/starknet.js",
        "require": "./dist/starknet.cjs"
      },
      "./near": {
        "types": "./dist/near.d.ts",
        "import": "./dist/near.js",
        "require": "./dist/near.cjs"
      },
      "./tron": {
        "types": "./dist/tron.d.ts",
        "import": "./dist/tron.js",
        "require": "./dist/tron.cjs"
      },
      "./cardano": {
        "types": "./dist/cardano.d.ts",
        "import": "./dist/cardano.js",
        "require": "./dist/cardano.cjs"
      },
      "./ton": {
        "types": "./dist/ton.d.ts",
        "import": "./dist/ton.js",
        "require": "./dist/ton.cjs"
      },
      "./hedera": {
        "types": "./dist/hedera.d.ts",
        "import": "./dist/hedera.js",
        "require": "./dist/hedera.cjs"
      },
      "./api": {
        "types": "./dist/api.d.ts",
        "import": "./dist/api.js",
        "require": "./dist/api.cjs"
      },
      "./protocol": {
        "types": "./dist/protocol.d.ts",
        "import": "./dist/protocol.js",
        "require": "./dist/protocol.cjs"
      },
      "./agent-profile": {
        "types": "./dist/agent-profile.d.ts",
        "import": "./dist/agent-profile.js",
        "require": "./dist/agent-profile.cjs"
      },
      "./evidence": {
        "types": "./dist/evidence.d.ts",
        "import": "./dist/evidence.js",
        "require": "./dist/evidence.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fileonchain/api": "workspace:^",
    "@fileonchain/sdk-aptos": "workspace:^",
    "@fileonchain/sdk-cardano": "workspace:^",
    "@fileonchain/sdk-cosmos": "workspace:^",
    "@fileonchain/sdk-evm": "workspace:^",
    "@fileonchain/sdk-hedera": "workspace:^",
    "@fileonchain/sdk-near": "workspace:^",
    "@fileonchain/sdk-solana": "workspace:^",
    "@fileonchain/sdk-starknet": "workspace:^",
    "@fileonchain/sdk-substrate": "workspace:^",
    "@fileonchain/sdk-sui": "workspace:^",
    "@fileonchain/sdk-ton": "workspace:^",
    "@fileonchain/sdk-tron": "workspace:^",
    "@fileonchain/utils": "workspace:^",
    "@fileonchain/protocol": "workspace:^",
    "@fileonchain/agent-profile": "workspace:^"
  },
  "peerDependencies": {
    "@polkadot/api": ">=15",
    "@solana/web3.js": "^1",
    "viem": "^2"
  },
  "peerDependenciesMeta": {
    "@polkadot/api": {
      "optional": true
    },
    "@solana/web3.js": {
      "optional": true
    },
    "viem": {
      "optional": true
    }
  },
  "devDependencies": {
    "@polkadot/api": "^15.10.2",
    "@solana/web3.js": "^1.98.4",
    "@types/node": "^20",
    "tsup": "^8.5.0",
    "typescript": "^5",
    "viem": "^2.53.1"
  }
}
